{
  "name": "freecode",
  "productName": "freeCode",
  "version": "1.0.0",
  "description": "freeCode — AI coding freedom for vibe coders. Professional architecture, agentic superpowers.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --dir --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "freecode",
    "vibe-coding",
    "ai",
    "coding-assistant",
    "electron",
    "windows"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.freecode.app",
    "productName": "freeCode",
    "copyright": "Copyright © 2025 freeCode — AI coding freedom for vibe coders",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "dialog-preload.js",
      "api-key-dialog.html",
      "renderer/**/*",
      "!renderer/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../vscode-extension/agent-bridge.mjs",
        "to": "agent-bridge.mjs"
      },
      {
        "from": "../v2/src",
        "to": "v2/src"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "renderer/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "freeCode"
    },
    "portable": {
      "artifactName": "freeCode-${version}-portable.exe"
    },
    "publish": null
  }
}
